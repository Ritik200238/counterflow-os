# CounterFlow OS — Environment template
# Copy this file to .env and fill in the real values. Do NOT commit .env.

# Alibaba Cloud / Qwen (DashScope) — LLM API for agent reasoning
DASHSCOPE_API_KEY=your_qwen_dashscope_key_here
QWEN_API_KEY=your_qwen_dashscope_key_here

# Bitget AI Agent Hub — intelligent agent skill key
# Install: npx @bitget-ai/getagent-skill install
BITGET_AGENT_API_KEY=your_bitget_agent_key_here
